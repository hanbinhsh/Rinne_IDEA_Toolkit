<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.hanbinhsh.rinneideatoolkit</id>
    <name>Rinne_IDEA_Toolkit</name>
    <vendor>hanbinhsh</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>com.intellij.modules.xml</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Method Call Graph"
                stripeTitle="%toolWindow.graphTitle"
                anchor="right"
                canCloseContents="true"
                factoryClass="com.github.hanbinhsh.rinneideatoolkit.toolWindow.MethodCallGraphToolWindowFactory"/>
    </extensions>

    <actions>
        <action
                id="RinneIdeaToolkit.AnalyzeMethodCalls"
                class="com.github.hanbinhsh.rinneideatoolkit.actions.AnalyzeMethodCallsAction"
                text="%action.analyzeMethodCalls.text"
                description="%action.analyzeMethodCalls.description">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
